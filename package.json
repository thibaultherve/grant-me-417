{
  "name": "regranted",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@10.28.1",
  "scripts": {
    "dev:client": "pnpm --filter @regranted/client dev",
    "dev:server": "pnpm --filter @regranted/server start:dev",
    "build:client": "pnpm --filter @regranted/client build",
    "build:server": "pnpm --filter @regranted/server build",
    "build:shared": "pnpm --filter @regranted/shared build",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test"
  },
  "devDependencies": {
    "knip": "^6.2.0",
    "typescript": "~5.8.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "esbuild",
      "unrs-resolver",
      "bcrypt"
    ]
  }
}
